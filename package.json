{
  "name": "taka",
  "private": true,
  "version": "0.1.0",
  "description": "Automated visual frontend testing platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "reset": "rm -rf ./data && mkdir -p ./data/{screenshots,recordings,diffs}",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "eslint": "^9.28.0",
    "eslint-config-custom": "workspace:*",
    "prettier": "^3.5.3",
    "turbo": "^2.8.12",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.12.0"
}
